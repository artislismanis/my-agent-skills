    { "id": "payClient",  "shape": "rect", "role": "internal",      "label": "PaymentClient\n[Component]\nPayment integration",    "size": [200, 100] },
    { "id": "invClient",  "shape": "rect", "role": "internal",      "label": "InventoryClient\n[Component]\nInventory checks",     "size": [200, 100] },
    { "id": "repo",       "shape": "rect", "role": "internal",      "label": "OrderRepository\n[Component]\nData persistence",     "size": [200, 100] },
    { "id": "payService", "shape": "rect", "role": "infrastructure", "label": "Payment Service\n[Container]",                     "size": [200, 100] },
    { "id": "invService", "shape": "rect", "role": "infrastructure", "label": "Inventory Service\n[Container]",                   "size": [200, 100] },
